# Server Port
PORT=3000

# Concurrency and Page Limits
MAX_CONCURRENT_JOBS=3
MAX_PAGES_PER_CRAWL=40
MAX_CRAWL_DEPTH=3
CRAWL_CONCURRENCY=3

# Resource and Size Limits
MAX_TOTAL_BYTES=524288000 # 500 MB in bytes
MAX_CRAWL_DURATION_MS=300000 # 5 minutes in milliseconds
PAGE_NAV_TIMEOUT_MS=30000 # 30 seconds in milliseconds

# Protocol and Scope Restrictions
ALLOWED_PROTOCOLS=http:,https:
ALLOW_SUBDOMAINS=false

# Cache and Rate Limiting
DOWNLOAD_TTL_MS=86400000 # 24 hours in milliseconds
RATE_LIMIT_PER_IP_PER_HOUR=5
